
# Stripe Configuration (Required)
# Get your keys from https://dashboard.stripe.com/apikeys
VITE_STRIPE_SECRET_KEY=sk_test_your_secret_key_here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# API Configuration
VITE_API_BASE_URL=https://your-domain.com

# Security Note: 
# - Never commit real secret keys to version control
# - Use Supabase Edge Functions for secure server-side operations
# - This .env.example file shows the required format only
